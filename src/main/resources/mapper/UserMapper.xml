<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.appointment.mapper.UserMapper">
    <resultMap id="BaseResultMap" type="com.appointment.entity.User">
        <id column="id" property="id"/>
        <result column="phone" property="phone"/>
        <result column="pwd" property="pwd"/>
        <result column="real_name" property="realName"/>
        <result column="id_card" property="idCard"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="last_login_time" property="lastLoginTime"/>
        <result column="status" property="status"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, phone, pwd, real_name, id_card, create_time, update_time, last_login_time, status
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user
        WHERE id = #{id}
    </select>

    <select id="selectByPhone" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user
        WHERE phone = #{phone}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user
        ORDER BY id DESC
    </select>

    <insert id="insert" parameterType="com.appointment.entity.User">
        INSERT INTO user (phone, pwd, real_name, id_card, status)
        VALUES (#{phone}, #{pwd}, #{realName}, #{idCard}, #{status})
    </insert>

    <update id="update" parameterType="com.appointment.entity.User">
        UPDATE user
        SET phone = #{phone}, real_name = #{realName}, id_card = #{idCard}, status = #{status}, update_time = NOW()
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM user WHERE id = #{id}
    </delete>

    <update id="updateLastLoginTime">
        UPDATE user
        SET last_login_time = NOW()
        WHERE id = #{id}
    </update>
</mapper>
