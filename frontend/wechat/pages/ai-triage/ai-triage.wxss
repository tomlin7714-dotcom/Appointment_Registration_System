/**pages/ai-triage/ai-triage.wxss**/

.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f7fa;
}

/* 头部提示 */
.header-tip {
  display: flex;
  align-items: center;
  padding: 16rpx 30rpx;
  background: linear-gradient(135deg, #e8f4f8 0%, #f0f8ff 100%);
  border-bottom: 1rpx solid #d0e8f0;
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #4a7a9c;
}

/* 对话区域 */
.chat-area {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.message-row {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-start;
}

.user-row {
  justify-content: flex-end;
}

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.ai-avatar {
  background: #e3f2fd;
  margin-right: 16rpx;
}

.user-avatar {
  background: #fff3e0;
  margin-left: 16rpx;
  order: 1;
}

.msg-content {
  max-width: 70%;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.ai-msg {
  background: #fff;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  border-top-left-radius: 4rpx;
}

.user-msg {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-top-right-radius: 4rpx;
}

.msg-text {
  display: block;
  white-space: pre-wrap;
}

.thinking {
  color: #999;
}

/* 推荐科室 */
.dept-recommend {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.recommend-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.recommend-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  margin-bottom: 8rpx;
  background: #f0f4ff;
  border-radius: 12rpx;
  border: 1rpx solid #d0d8f0;
}

.recommend-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.recommend-arrow {
  font-size: 24rpx;
  color: #667eea;
}

/* 快捷症状 */
.quick-symptoms {
  padding: 20rpx;
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
}

.qs-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.qs-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.qs-tag {
  padding: 12rpx 24rpx;
  background: #f0f4ff;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #667eea;
  border: 1rpx solid #d0d8f0;
}

/* 底部输入栏 */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.text-input {
  flex: 1;
  height: 72rpx;
  background: #f5f7fa;
  border-radius: 36rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #333;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  margin-left: 16rpx;
  padding: 0;
}

.send-btn.disabled {
  opacity: 0.5;
}
