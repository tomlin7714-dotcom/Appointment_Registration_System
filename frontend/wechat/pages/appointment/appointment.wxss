/**pages/appointment/appointment.wxss**/

.page-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 120rpx;
}

/* 医生信息卡片 */
.doctor-card {
  display: flex;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  color: #fff;
}

.doctor-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3);
  margin-right: 30rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 70rpx;
}

.doctor-info {
  flex: 1;
}

.doctor-name-wrapper {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.doctor-name {
  font-size: 40rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.doctor-title {
  font-size: 24rpx;
  background: rgba(255,255,255,0.3);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.doctor-dept {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 12rpx;
}

.doctor-desc {
  font-size: 24rpx;
  opacity: 0.8;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 日期选择 */
.date-list {
  white-space: nowrap;
  margin: 0 -10rpx;
}

.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 30rpx;
  margin: 0 10rpx;
  border-radius: 12rpx;
  background: #f5f7fa;
  min-width: 120rpx;
}

.date-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.date-week {
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.date-day {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.date-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.date-status.available {
  background: #e8f5e9;
  color: #388e3c;
}

.date-status.full {
  background: #ffebee;
  color: #d32f2f;
}

.date-item.active .date-status.available,
.date-item.active .date-status.full {
  background: rgba(255,255,255,0.3);
  color: #fff;
}

/* 时间段选择 */
.time-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.time-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  text-align: center;
}

.time-item.active {
  border-color: #667eea;
  background: #f3e5f5;
}

.time-item.disabled {
  opacity: 0.5;
  background: #f5f5f5;
}

.time-range {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.time-price {
  font-size: 24rpx;
  color: #f57c00;
  margin-bottom: 8rpx;
}

.time-remain {
  font-size: 20rpx;
  color: #388e3c;
}

.time-remain.full {
  color: #999;
}

/* 就诊人信息 */
.patient-info {
  padding: 10rpx 0;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.price-info {
  display: flex;
  align-items: baseline;
}

.price-label {
  font-size: 28rpx;
  color: #666;
}

.price-value {
  font-size: 40rpx;
  color: #f57c00;
  font-weight: bold;
}

.submit-btn {
  width: 280rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  border: none;
}

.submit-btn.disabled {
  opacity: 0.6;
  background: #ccc;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}