<!--pages/appointment-list/appointment-list.wxml-->
<view class="page-container">
  <!-- 状态筛选 -->
  <view class="filter-bar">
    <view class="filter-item {{currentFilter === '' ? 'active' : ''}}" bindtap="filterByStatus" data-status="">
      全部
    </view>
    <view class="filter-item {{currentFilter === '1' ? 'active' : ''}}" bindtap="filterByStatus" data-status="1">
      待就诊
    </view>
    <view class="filter-item {{currentFilter === '3' ? 'active' : ''}}" bindtap="filterByStatus" data-status="3">
      已完成
    </view>
    <view class="filter-item {{currentFilter === '4' ? 'active' : ''}}" bindtap="filterByStatus" data-status="4">
      已取消
    </view>
  </view>

  <!-- 预约列表 -->
  <scroll-view class="appointment-list" scroll-y="true" refresher-enabled="true" refresher-triggered="{{isRefreshing}}" bindrefresherrefresh="onRefresh">
    <view class="appointment-item" wx:for="{{appointmentList}}" wx:key="id">
      <view class="appointment-header">
        <view class="hospital-info">
          <text class="hospital-name">🏥 医疗预约系统</text>
          <text class="appointment-status status-{{item.status}}">{{item.statusText}}</text>
        </view>
      </view>
      
      <view class="appointment-body" bindtap="viewDetail" data-id="{{item.id}}">
        <view class="doctor-info">
          <view class="doctor-avatar-text">👨‍⚕️</view>
          <view class="doctor-detail">
            <view class="doctor-name-wrapper">
              <text class="doctor-name">{{item.doctorName}}</text>
              <text class="doctor-title">{{item.doctorTitle}}</text>
            </view>
            <text class="doctor-dept">{{item.deptName}}</text>
          </view>
        </view>
        
        <view class="appointment-info">
          <view class="info-row">
            <text class="info-label">就诊时间</text>
            <text class="info-value">{{item.visitDate}} {{item.visitTime}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">就诊地点</text>
            <text class="info-value">{{item.area}}{{item.deptName}}{{item.roomNumber}}诊室</text>
          </view>
          <view class="info-row">
            <text class="info-label">患者姓名</text>
            <text class="info-value">{{item.patientName}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">挂号费用</text>
            <text class="info-value price">¥{{item.fee}}</text>
          </view>
        </view>
      </view>
      
      <view class="appointment-footer">
        <view class="order-info">
          <text class="order-no">订单号：{{item.id}}</text>
        </view>
        <view class="action-btns">
          <block wx:if="{{item.status === 0}}">
            <button class="btn btn-default" bindtap="cancelAppointment" data-id="{{item.id}}">取消预约</button>
            <button class="btn btn-primary" bindtap="payAppointment" data-id="{{item.id}}">立即支付</button>
          </block>
          <block wx:if="{{item.status === 1}}">
            <text class="waiting-text">等待叫号中...</text>
          </block>
          <block wx:if="{{item.status === 2}}">
            <text class="visiting-text">就诊中...</text>
          </block>
          <block wx:if="{{item.status === 3}}">
            <text class="completed-text">已完成</text>
          </block>
          <block wx:if="{{item.status === 4}}">
            <text class="cancelled-text">已取消</text>
          </block>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{appointmentList.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无预约记录</text>
      <button class="btn btn-primary" style="width: 300rpx; margin-top: 40rpx;" bindtap="goToHome">去预约</button>
    </view>
  </scroll-view>
</view>
