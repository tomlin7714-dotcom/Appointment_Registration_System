/**pages/appointment-list/appointment-list.wxss**/

.page-container {
  min-height: 100vh;
  background: #f5f7fa;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.filter-item.active {
  color: #667eea;
  font-weight: 500;
}

.filter-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 2rpx;
}

/* 预约列表 */
.appointment-list {
  height: calc(100vh - 100rpx);
  padding: 20rpx;
}

.appointment-item {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.appointment-header {
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.hospital-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hospital-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.appointment-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.status-0 {
  background: #e3f2fd;
  color: #1976d2;
}

.status-1 {
  background: #e8f5e9;
  color: #388e3c;
}

.status-2 {
  background: #ffebee;
  color: #d32f2f;
}

/* 预约内容 */
.appointment-body {
  padding: 30rpx;
}

.doctor-info {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.doctor-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #f0f0f0;
}

.doctor-detail {
  flex: 1;
}

.doctor-name-wrapper {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.doctor-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-right: 16rpx;
}

.doctor-title {
  font-size: 24rpx;
  color: #667eea;
  background: #e3f2fd;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.doctor-dept {
  font-size: 26rpx;
  color: #666;
}

/* 预约信息 */
.appointment-info {
  padding: 10rpx 0;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #333;
}

.info-value.price {
  color: #f57c00;
  font-weight: 500;
}

/* 预约底部 */
.appointment-footer {
  padding: 20rpx 30rpx;
  background: #fafafa;
}

.order-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.order-no {
  font-size: 24rpx;
  color: #999;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.action-btns {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.btn {
  min-width: 160rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 32rpx;
  font-size: 26rpx;
  padding: 0 24rpx;
  border: none;
}

.btn-default {
  background: #f0f0f0;
  color: #666;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}