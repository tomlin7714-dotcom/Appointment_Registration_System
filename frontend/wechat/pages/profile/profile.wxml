<!--pages/profile/profile.wxml-->
<view class="page-container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-info">
      <view class="user-avatar">
        <text class="avatar-text">{{userInfo.realName ? userInfo.realName[0] : '👤'}}</text>
      </view>
      <view class="user-detail">
        <text class="user-name">{{userInfo.realName || '未登录'}}</text>
        <text class="user-phone" wx:if="{{userInfo.phone}}">{{userInfo.phone}}</text>
      </view>
    </view>
    <view class="user-stats">
      <view class="stat-item" bindtap="goToAppointment">
        <text class="stat-num">{{stats.pending}}</text>
        <text class="stat-label">待就诊</text>
      </view>
      <view class="stat-item" bindtap="goToAppointment">
        <text class="stat-num">{{stats.completed}}</text>
        <text class="stat-label">已完成</text>
      </view>
      <view class="stat-item" bindtap="goToAppointment">
        <text class="stat-num">{{stats.total}}</text>
        <text class="stat-label">全部预约</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="editProfile">
      <view class="menu-icon" style="background: #e3f2fd;">👤</view>
      <view class="menu-content">
        <text class="menu-title">个人信息</text>
        <text class="menu-desc">查看和修改个人资料</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
    
    <view class="menu-item" bindtap="goToAppointment">
      <view class="menu-icon" style="background: #e8f5e9;">📋</view>
      <view class="menu-content">
        <text class="menu-title">我的预约</text>
        <text class="menu-desc">查看预约记录</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
    
    <view class="menu-item" bindtap="goToFavorites">
      <view class="menu-icon" style="background: #fff3e0;">⭐</view>
      <view class="menu-content">
        <text class="menu-title">我的收藏</text>
        <text class="menu-desc">收藏的科医生</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
    
    <view class="menu-item" bindtap="goToConsultationHistory">
      <view class="menu-icon" style="background: #f3e5f5;">📄</view>
      <view class="menu-content">
        <text class="menu-title">问诊历史</text>
        <text class="menu-desc">查看问诊记录和诊断结果</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <!-- 其他功能 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="contactService">
      <view class="menu-icon" style="background: #e0f2f1;">💬</view>
      <view class="menu-content">
        <text class="menu-title">联系客服</text>
        <text class="menu-desc">遇到问题？联系我们</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
    
    <view class="menu-item" bindtap="aboutUs">
      <view class="menu-icon" style="background: #eceff1;">ℹ️</view>
      <view class="menu-content">
        <text class="menu-title">关于我们</text>
        <text class="menu-desc">版本信息 v1.0.0</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <!-- 登录/退出按钮 -->
  <view class="action-section">
    <button class="btn btn-primary" wx:if="{{!isLoggedIn}}" bindtap="goToLogin">登录</button>
    <button class="btn btn-default" wx:if="{{isLoggedIn}}" bindtap="logout">退出登录</button>
  </view>
</view>