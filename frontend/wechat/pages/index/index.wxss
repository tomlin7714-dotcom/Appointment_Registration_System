/**pages/index/index.wxss**/

/* 搜索栏 */
.search-bar {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx 30rpx 40rpx;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 16rpx 30rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  color: #999;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.clear-icon {
  font-size: 32rpx;
  color: #999;
  padding: 10rpx;
}

/* 搜索结果 */
.search-results {
  background: #f5f7fa;
  min-height: 100vh;
}

.search-results-content {
  padding: 20rpx;
}

.result-section {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.result-title {
  font-size: 28rpx;
  color: #666;
  padding: 24rpx 30rpx 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-list {
  padding: 0 30rpx;
}

.result-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-item:last-child {
  border-bottom: none;
}

.result-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.result-name {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.result-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.doctor-result {
  padding: 20rpx 0;
}

.result-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.result-info {
  flex: 1;
}

.result-info .result-name {
  display: block;
  margin-bottom: 8rpx;
}

.result-desc {
  font-size: 24rpx;
  color: #999;
}

.no-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.no-result-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.no-result-text {
  font-size: 28rpx;
  color: #999;
}

/* 轮播图 */
.banner {
  height: 300rpx;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-item {
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: #fff;
}

.banner-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.banner-desc {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 快捷入口 */
.quick-entry {
  display: flex;
  justify-content: space-around;
  background: #fff;
  padding: 30rpx 20rpx;
  margin: 20rpx;
  border-radius: 16rpx;
}

.entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.entry-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.entry-text {
  font-size: 26rpx;
  color: #666;
}

/* 推荐科室 */
.dept-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.dept-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.dept-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f5f7fa;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.dept-name {
  font-size: 24rpx;
  color: #666;
}

/* 推荐医生 */
.doctor-list {
  margin-top: 10rpx;
}

.doctor-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.doctor-item:last-child {
  border-bottom: none;
}

.doctor-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.doctor-info {
  flex: 1;
}

.doctor-name-wrapper {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.doctor-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-right: 16rpx;
}

.doctor-title {
  font-size: 24rpx;
  color: #667eea;
  background: #e3f2fd;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.doctor-dept {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.doctor-desc {
  font-size: 24rpx;
  color: #999;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.doctor-action {
  margin-left: 20rpx;
}

.btn-appointment {
  display: inline-block;
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 28rpx;
  font-size: 26rpx;
}

/* 更多 */
.more {
  font-size: 26rpx;
  color: #999;
}

/* 公告栏 */
.notice-bar {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx 30rpx;
  margin: 20rpx;
  border-radius: 16rpx;
}

.notice-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.notice-swiper {
  flex: 1;
  height: 40rpx;
}

.notice-text {
  font-size: 26rpx;
  color: #666;
  line-height: 40rpx;
}