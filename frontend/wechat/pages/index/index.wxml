<!--pages/index/index.wxml-->
<view class="page-container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrapper">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索科室或医生" bindinput="onSearchInput" value="{{searchKeyword}}" />
      <text class="clear-icon" wx:if="{{searchKeyword}}" bindtap="clearSearch">✕</text>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view class="search-results" wx:if="{{showSearchResults}}">
    <view class="search-results-content">
      <!-- 科室结果 -->
      <view class="result-section" wx:if="{{searchResults.depts.length > 0}}">
        <view class="result-title">科室</view>
        <view class="result-list">
          <view class="result-item" wx:for="{{searchResults.depts}}" wx:key="id" bindtap="selectSearchDept" data-id="{{item.id}}">
            <text class="result-icon">🏥</text>
            <text class="result-name">{{item.deptName}}</text>
            <text class="result-arrow">></text>
          </view>
        </view>
      </view>
      
      <!-- 医生结果 -->
      <view class="result-section" wx:if="{{searchResults.doctors.length > 0}}">
        <view class="result-title">医生</view>
        <view class="result-list">
          <view class="result-item doctor-result" wx:for="{{searchResults.doctors}}" wx:key="id" bindtap="selectSearchDoctor" data-id="{{item.id}}">
            <view class="result-avatar">{{item.avatar || '👨‍⚕️'}}</view>
            <view class="result-info">
              <text class="result-name">{{item.name}}</text>
              <text class="result-desc">{{item.title}} | {{item.deptName}}</text>
            </view>
            <text class="result-arrow">></text>
          </view>
        </view>
      </view>
      
      <!-- 无结果 -->
      <view class="no-result" wx:if="{{searchResults.depts.length === 0 && searchResults.doctors.length === 0}}">
        <text class="no-result-icon">🔍</text>
        <text class="no-result-text">未找到相关结果</text>
      </view>
    </view>
  </view>

  <!-- 正常内容（非搜索状态显示） -->
  <view wx:if="{{!showSearchResults}}">
    <!-- 轮播图 -->
    <swiper class="banner" indicator-dots="true" autoplay="true" interval="3000" duration="500">
      <swiper-item>
        <view class="banner-item" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
          <text class="banner-title">专业医疗预约平台</text>
          <text class="banner-desc">随时随地，轻松预约</text>
        </view>
      </swiper-item>
      <swiper-item>
        <view class="banner-item" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
          <text class="banner-title">优质医生资源</text>
          <text class="banner-desc">三甲医院专家在线</text>
        </view>
      </swiper-item>
    </swiper>

    <!-- 快捷入口 -->
    <view class="quick-entry">
      <view class="entry-item" bindtap="goToAppointmentBooking">
        <view class="entry-icon" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; font-size: 40rpx;">📅</view>
        <text class="entry-text">预约挂号</text>
      </view>
      <view class="entry-item" bindtap="goToAppointment">
        <view class="entry-icon" style="background: #fff3e0;">📋</view>
        <text class="entry-text">我的预约</text>
      </view>
      <view class="entry-item" bindtap="goToProfile">
        <view class="entry-icon" style="background: #f3e5f5;">👤</view>
        <text class="entry-text">个人中心</text>
      </view>
    </view>

    <!-- 推荐科室 -->
    <view class="card">
      <view class="card-header">
        <text class="card-title">推荐科室</text>
        <text class="more" bindtap="goToDept">更多 ></text>
      </view>
      <view class="dept-grid">
        <view class="dept-item" wx:for="{{deptList}}" wx:key="id" bindtap="selectDept" data-id="{{item.id}}">
          <view class="dept-icon">{{item.icon}}</view>
          <text class="dept-name">{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 推荐医生 -->
    <view class="card">
      <view class="card-header">
        <text class="card-title">推荐医生</text>
        <text class="more" bindtap="goToDoctor">更多 ></text>
      </view>
      <view class="doctor-list">
        <view class="doctor-item" wx:for="{{doctorList}}" wx:key="id" bindtap="selectDoctor" data-id="{{item.id}}">
          <view class="doctor-avatar">{{item.avatar || '👨‍⚕️'}}</view>
          <view class="doctor-info">
            <view class="doctor-name-wrapper">
              <text class="doctor-name">{{item.name}}</text>
              <text class="doctor-title">{{item.title}}</text>
            </view>
            <text class="doctor-dept">{{item.deptName}}</text>
            <text class="doctor-desc">{{item.remark || '擅长各类常见病、多发病的诊治'}}</text>
          </view>
          <view class="doctor-action">
            <text class="btn-appointment">预约</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 公告栏 -->
    <view class="notice-bar">
      <text class="notice-icon">📢</text>
      <swiper class="notice-swiper" vertical="true" autoplay="true" interval="3000" duration="500">
        <swiper-item>
          <text class="notice-text">欢迎使用医疗预约系统，请提前预约挂号</text>
        </swiper-item>
        <swiper-item>
          <text class="notice-text">就诊时请携带身份证和医保卡</text>
        </swiper-item>
      </swiper>
    </view>
  </view>
</view>