<!--pages/login/login.wxml-->
<view class="login-container">
  <view class="login-header">
    <view class="logo">🏥</view>
    <text class="title">医疗预约系统</text>
    <text class="subtitle">欢迎回来，请登录</text>
  </view>

  <view class="login-form">
    <view class="form-group">
      <text class="form-label">手机号</text>
      <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
    </view>

    <view class="form-group">
      <text class="form-label">密码</text>
      <input class="form-input" type="password" placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" />
    </view>

    <button class="btn btn-primary" bindtap="login" loading="{{isLoading}}">登录</button>

    <view class="login-options">
      <text class="link" bindtap="goToRegister">注册账号</text>
      <text class="link">忘记密码？</text>
    </view>
  </view>

  <view class="login-footer">
    <text class="agreement">登录即表示同意《用户协议》和《隐私政策》</text>
  </view>
</view>