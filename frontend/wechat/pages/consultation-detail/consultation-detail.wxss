/**pages/consultation-detail/consultation-detail.wxss**/

.page-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 20rpx;
}

.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.card-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  background: #e3f2fd;
  color: #1976d2;
}

.card-status.completed {
  background: #e8f5e9;
  color: #388e3c;
}

.card-status.cancelled {
  background: #fce4ec;
  color: #c62828;
}

.info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.info-row.multi-line {
  flex-direction: column;
}

.info-row:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
  width: 140rpx;
  margin-bottom: 8rpx;
}

.multi-line .label {
  margin-bottom: 8rpx;
}

.value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.value-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.doctor-title-tag {
  font-size: 22rpx;
  color: #667eea;
  background: #f0f4ff;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  margin-left: 8rpx;
}
