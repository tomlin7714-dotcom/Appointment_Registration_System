/* pages/register/register.wxss */
.register-container {
  padding: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.register-header {
  text-align: center;
  padding: 60rpx 0;
}

.logo {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.register-form {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-top: 40rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 90rpx;
  padding: 0 30rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #667eea;
}

.btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 20rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.btn-primary::after {
  border: none;
}

.register-options {
  text-align: center;
  margin-top: 30rpx;
}

.link {
  font-size: 28rpx;
  color: #667eea;
}

.register-footer {
  text-align: center;
  margin-top: 40rpx;
}

.agreement {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}
